# Supabase (Project Settings -> API)
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOi...

# Solo servidor. Salta RLS: nunca lo prefijes con NEXT_PUBLIC_.
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOi...

# Usado para construir el enlace de retorno del magic link.
# En local: http://localhost:3000 — en Vercel: https://pactify.vercel.app
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Claude (generación de itinerarios)
ANTHROPIC_API_KEY=sk-ant-...

# true  = el endpoint devuelve un JSON de ejemplo, NO llama a Claude, 0 tokens.
# false = llamada real a la API.
# Cualquier valor distinto de "false" se trata como true (se falla al lado seguro).
USE_MOCK_AI=true

# Modelo para generar/regenerar itinerarios en producción. Sonnet por
# defecto -Opus se reserva para las sesiones de Claude Code mientras se
# programa, no para las llamadas reales de la app-. Déjalo sin definir para
# usar el default; ponlo solo si quieres probar con otro modelo puntualmente.
# ANTHROPIC_MODEL=claude-sonnet-5

# MapTiler (mapa)
NEXT_PUBLIC_MAPTILER_KEY=
